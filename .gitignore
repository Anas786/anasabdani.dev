node_modules
dist
dist-ssr

# Override global gitignore — we DO want lockfiles in this repo
# so Vercel/CI installs the exact same versions.
!package-lock.json
*.local
.DS_Store
.vite
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local dev tooling (Claude Code / OMC) — machine-specific, not for VCS
.claude/
.omc/

# Editor/OS
.vscode/
.idea/
*.swp
*.swo
